# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend/Server-side only (DO NOT expose in frontend)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Project ID (for reference)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# VideoSDK Configuration
# Frontend (optional - only if needed for client-side validation)
VITE_VIDEOSDK_API_KEY=your_videosdk_api_key_here
VITE_VIDEOSDK_SECRET=your_videosdk_secret_here

# Backend/Server-side (for Edge Functions - REQUIRED)
# VIDEOSDK_API_KEY=your_videosdk_api_key_here
# VIDEOSDK_SECRET=your_videosdk_secret_here
