# ===========================================
# AI Interview Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your credentials

# -------------------------------------------
# VideoSDK Configuration (Required)
# -------------------------------------------
# Get these from https://app.videosdk.live
# Token is generated AUTOMATICALLY from API key + secret

VIDEOSDK_API_KEY=your-api-key-here
VIDEOSDK_SECRET=your-secret-key-here

# -------------------------------------------
# Supabase Configuration (Required for auto-detect)
# -------------------------------------------
# Get these from your Supabase project settings

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------
# Google Gemini API (Required)
# -------------------------------------------
# Get API key from https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=your-gemini-api-key-here

# -------------------------------------------
# Optional Configuration
# -------------------------------------------

# Gemini voice options: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr
GEMINI_VOICE=Leda

# Name shown for the AI agent in the meeting
AGENT_NAME=AI Interviewer

# Fallback interview settings (used when not auto-detected from database)
INTERVIEW_TYPE=Python
DIFFICULTY_LEVEL=Medium
CANDIDATE_NAME=Candidate
DURATION_MINUTES=30
JOB_TITLE=Software Developer
CODING_ROUND=false
