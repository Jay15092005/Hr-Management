# ===========================================
# AI Interview Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your credentials

# -------------------------------------------
# VideoSDK Configuration (Required)
# -------------------------------------------
# Get these from https://app.videosdk.live
# Token is generated AUTOMATICALLY from API key + secret

VIDEOSDK_API_KEY=your-api-key-here
VIDEOSDK_SECRET=your-secret-key-here

# -------------------------------------------
# Supabase Configuration (Required for auto-detect)
# -------------------------------------------
# SERVICE ROLE is required: the agent runs outside the browser and must bypass RLS
# on interview_configurations. Never commit this key or use it in frontend code.

# Same project URL as the React app (either name works; Vite often uses VITE_ prefix only)
SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_URL=https://your-project.supabase.co

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: set to true only if you need HTTP/2 for PostgREST. Default leaves HTTP/2 off
# because httpx+HTTP/2 often hangs on the first request on some networks (no "New interview" logs).
# SUPABASE_HTTP2=true

# Optional: anon key is not sufficient for polling due to RLS (kept for reference)
# SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------
# Google Gemini API (Required)
# -------------------------------------------
# Get API key from https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=your-gemini-api-key-here

# -------------------------------------------
# Optional Configuration
# -------------------------------------------

# Gemini voice options: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr
GEMINI_VOICE=Leda

# Name shown for the AI agent in the meeting
AGENT_NAME=AI Interviewer

# Fallback interview settings (used when not auto-detected from database)
INTERVIEW_TYPE=Python
DIFFICULTY_LEVEL=Medium
CANDIDATE_NAME=Candidate
DURATION_MINUTES=30
JOB_TITLE=Software Developer
CODING_ROUND=false
